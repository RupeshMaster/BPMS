# Port for the Express backend server
PORT=5000

# MongoDB Connection URI
# Local fallback: mongodb://127.0.0.1:27017/bharat_petroleum
# Atlas format: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/bharat_petroleum?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/bharat_petroleum

# JSON Web Token Secret Key
JWT_SECRET=bharat_secret_key
